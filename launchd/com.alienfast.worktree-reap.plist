<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  TEMPLATE for the local worktree reaper (launchd, macOS only). The __HOME__ tokens are placeholders:
  launchd requires absolute paths and does NOT expand ~ or $HOME, so this is NOT loaded as-is.

  update.sh installs/refreshes it automatically: it renders __HOME__ → $HOME into
  ~/Library/LaunchAgents/com.alienfast.worktree-reap.plist and bootstraps it (idempotently).
  To do it by hand:

    sed "s|__HOME__|$HOME|g" ~/.claude/launchd/com.alienfast.worktree-reap.plist \
      > ~/Library/LaunchAgents/com.alienfast.worktree-reap.plist
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.alienfast.worktree-reap.plist

  To remove:

    launchctl bootout gui/$(id -u)/com.alienfast.worktree-reap
    rm ~/Library/LaunchAgents/com.alienfast.worktree-reap.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.alienfast.worktree-reap</string>

  <key>ProgramArguments</key>
  <array>
    <string>__HOME__/.claude/scripts/reap-worktrees-cron.sh</string>
  </array>

  <key>StartInterval</key>
  <integer>3600</integer>

  <key>RunAtLoad</key>
  <false/>

  <key>ProcessType</key>
  <string>Background</string>

  <key>StandardOutPath</key>
  <string>__HOME__/.claude/logs/worktree-reap.launchd.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/.claude/logs/worktree-reap.launchd.log</string>
</dict>
</plist>
