      "Bash(mkdir -p:*)",
      "Bash(mkdir:*)",
      "Bash(moon run:*)",
      "Bash(mv:*)",
      "Bash(ncu:*)",
      "Bash(node:*)",
      "Bash(npm info:*)",
      "Bash(npm ls:*)",
      "Bash(npm run:*)",
      "Bash(npm view:*)",
      "Bash(npx:*)",
      "Bash(open:*)",
      "Bash(perl:*)",
      "Bash(pkill:*)",
      "Bash(pnpm:*)",
      "Bash(python3:*)",
      "Bash(rm:*)",
      "Bash(rg:*)",
      "Bash(rspec apps/api/spec --format progress)",
      "Bash(rvm list:*)",
      "Bash(rvm use:*)",
      "Bash(sed -n:*)",
      "Bash(tee:*)",
      "Bash(test:*)",
      "Bash(then:*)",
      "Bash(time:*)",
      "Bash(timeout:*)",
      "Bash(tree:*)",
      "Bash(unset:*)",
      "Bash(uv:*)",
      "Bash(wait:*)",
      "Bash(wc -l:*)",
      "Bash(xargs:*)",
      "Bash(yarn:*)",
      "Bash(~/.claude/scripts/linear-stdin.sh *)",
      "Bash(~/.claude/skills/pr-update/scripts/analyze-pr.sh:*)",
      "Bash(~/.claude/skills/pr-update/scripts/verify-feature.sh:*)",
      "Edit(~/.claude/skills/start/**)",
      "Read(//Users/*/.claude/**)",
      "Read(//Users/*/.rvm/gems/**)",
      "Read(//Users/*/projects/**)",
      "Read(//private/tmp/**)",
      "Read(//tmp/**)",
      "Read(/tmp/**)",
      "Skill",
      "Skill(pr-update)",
      "WebFetch",
      "WebFetch(domain:*)",
      "WebSearch",
      "Write(//private/tmp/**)",
      "Write(//tmp/**)",
      "Write(/tmp/**)",
      "mcp__agent-browser__frame",
      "mcp__circleci",
      "mcp__ide__getDiagnostics",
      "mcp__mui",
      "Bash(.claude/skills/investigate/scripts/preflight.sh --need kubectl,gcloud,pulumi,jq,curl)",
      "mcp__descope-docs__search-descope-docs",
      "mcp__descope-docs__ask-question-about-descope",
      "Bash(~/.claude/scripts/next-candidates.sh)",
      "Bash(~/.claude/scripts/linear-post.sh comment *)",
      "Bash(~/.claude/scripts/linear-post.sh description *)",
      "Bash(~/.claude/scripts/linear-context.sh *)",
      "Bash(~/.claude/scripts/linear-deps-graph.sh *)",
      "Bash(~/.claude/scripts/linear-create-child.sh *)",
      "Bash(~/.claude/scripts/mark-ready-for-release.sh *)"
    ],
    "deny": [],
    "ask": [
      "mcp__circleci__run_pipeline"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/private/tmp"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/git-permissions.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/full-continue.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "skipAutoPermissionPrompt": true
}
