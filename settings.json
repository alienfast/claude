      "Bash(du:*)",
      "Bash(echo:*)",
      "Bash(elif:*)",
      "Bash(else:*)",
      "Bash(env)",
      "Bash(export:*)",
      "Bash(fi)",
      "Bash(find:*)",
      "Bash(for:*)",
      "Bash(gcloud iam roles describe:*)",
      "Bash(gcloud iam roles list:*)",
      "Bash(gcloud projects get-iam-policy:*)",
      "Bash(gcloud sql flags list:*)",
      "Bash(gcloud sql users describe:*)",
      "Bash(gcloud sql users list:*)",
      "Bash(gh:*)",
      "Bash(git add:*)",
      "Bash(git mv:*)",
      "Bash(git:*)",
      "Bash(gpg --version:*)",
      "Bash(gpgconf --list-dirs:*)",
      "Bash(grep:*)",
      "Bash(if:*)",
      "Bash(jq:*)",
      "Bash(kill:*)",
      "Bash(kubectl config get-contexts:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl logs:*)",
