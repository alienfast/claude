{
  "default": true,
  // MD013 (line-length): we wrap prose at ~160, not 80.
  "MD013": false,
  // MD060 (table-column-style): newly default-on in markdownlint 0.40 and has NO auto-fixer, so
  // `--fix` can never repair it — every existing table (delimiter rows without the single-space
  // padding the data rows use) fails forever. With style "any" it also flip-flops between
  // "compact" and "aligned" per table, so there is no stable target to hand-fix toward. Purely
  // cosmetic; our GFM tables are already readable. Off.
  "MD060": false
}